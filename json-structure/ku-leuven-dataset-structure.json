    "createDate": { "type": "string", "format": "date-time" },
    "modificationTime": { "type": "string", "format": "date-time" },
    "released": { "type": "boolean" },
    "identifierRegistered": { "type": "boolean" },
    "authorString": { "type": "string" },
    "metadataLanguage": { "type": "string" },
